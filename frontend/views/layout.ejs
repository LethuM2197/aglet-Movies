<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <% if (currentPath !== '/auth/login') { %>
    <nav class="nav">
      <a href="/" class="nav__logo">
        <span class="nav__logo-icon">▶</span>
        <span>MOVIEDB</span>
      </a>

      <div class="nav__search" id="searchWrapper">
        <input
          type="text"
          id="searchInput"
          class="nav__search-input"
          placeholder="Search films…"
          autocomplete="off"
        />
        <div class="nav__search-results" id="searchResults"></div>
      </div>

      <div class="nav__links" id="navLinks">
        <a href="/"           class="nav__link <%= currentPath === '/'            ? 'active' : '' %>">Films</a>
        <a href="/favourites" class="nav__link <%= currentPath === '/favourites'  ? 'active' : '' %>">Favourites</a>
        <a href="/contact"    class="nav__link <%= currentPath === '/contact'     ? 'active' : '' %>">Contact</a>

        <% if (user) { %>
          <div class="nav__user">
            <span class="nav__username">@<%= user.username %></span>
            <a href="/auth/logout" class="nav__link nav__link--logout">Logout</a>
          </div>
        <% } else { %>
          <a href="/auth/login" class="nav__link nav__link--cta">Login</a>
        <% } %>
      </div>

      <button class="nav__hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
  <% } %>

  <main class="main">
    <%- body %>
  </main>

  <footer class="footer">
    <div class="footer__inner">
      <p class="footer__copy">© 2024 MovieDB · Built for Aglet Interactive</p>
      <p class="footer__credit">Powered by <a href="https://www.themoviedb.org" target="_blank">TMDB</a></p>
    </div>
  </footer>

  <!-- Movie Detail Modal -->
  <div class="modal" id="movieModal" aria-hidden="true">
    <div class="modal__backdrop" id="modalBackdrop"></div>
    <div class="modal__panel">
      <button class="modal__close" id="modalClose">✕</button>
      <div class="modal__content" id="modalContent">
        <div class="modal__loader">Loading…</div>
      </div>
    </div>
  </div>

  <!-- Toast notification -->
  <div class="toast" id="toast"></div>

  <script src="/js/main.js"></script>
</body>
</html>